rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isStaff() {
      return request.auth != null
        && request.auth.token.email == "staff@wildly.com.au";
    }

    match /dashboardConfig/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }
  }
}
